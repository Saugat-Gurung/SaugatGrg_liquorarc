<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_centerInParent="true"
    android:background="@color/white"
    android:orientation="vertical"
    android:id="@+id/mainLL"
    android:padding="10dp">


    <ImageView
        android:id="@+id/productIV"
        android:layout_width="146dp"
        android:layout_height="150dp"
        android:layout_marginBottom="10dp"
        android:src="@drawable/heineken" />

    <TextView
        android:id="@+id/productNameTV"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Heineken Beer"
        android:fontFamily="@font/roboto_regular"
        android:textSize="16sp"
        android:layout_marginTop="5dp"/>

    <TextView
        android:id="@+id/discountPriceTV"
        android:text="Rs. 650"
        android:fontFamily="@font/roboto_regular"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="2"
        android:textColor="@color/orange"
        android:textSize="18sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:text="Rs. 900"
            android:id="@+id/oldPriceTV"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:foreground="@drawable/strike"
            android:maxLines="2"
            android:fontFamily="@font/roboto_regular"
            android:textColor="@color/priceGray"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/discountPercentTV"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:maxLines="2"
            android:textColor="@color/black"
            android:textSize="14sp" />
    </LinearLayout>



</LinearLayout>

